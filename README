  启动方式

  # 1. 启动 MySQL，创建数据库（自动建表）
  mysql -u root -p -e "CREATE DATABASE IF NOT EXISTS admin_system"

  # 2. 启动后端（端口 8080）
  cd backend && mvn spring-boot:run

  # 3. 启动前端（端口 3000，代理到 8080）
  cd frontend && npm run dev

  # 打包，然后把dist 拷贝到spring boot 项目
  npm run build

  默认账号：admin / admin123

  数据库表关系

  sys_user ──M:N── sys_user_role ──M:N── sys_role ──M:N── sys_role_permission ──M:N── sys_permission
                                                  │
  sys_notification (user_id)                      └── 树形结构 (parent_id)
  sys_file_record (upload_user_id)

